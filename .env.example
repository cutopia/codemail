# Codemail Configuration Example

# Email Server Settings (IMAP/SMTP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your email address and app password
EMAIL_ADDRESS=codemail@yourdomain.com
EMAIL_PASSWORD=your_app_password_here

# Codemail Settings
CODEMAIL_PREFIX=codemail:

# Security - Email Whitelist Configuration
# Format: comma-separated email addresses (case-insensitive)
# Use @domain.com format to whitelist entire domains

# Who is allowed to submit tasks (incoming emails)
EMAIL_WHITELIST_SENDERS="admin@yourdomain.com,dev@yourdomain.com"

# Who can receive task completion reports (outgoing emails)
EMAIL_WHITELIST_RECIPIENTS="admin@yourdomain.com,devops@yourdomain.com"

# Optional: LLM Configuration
LLM_ENDPOINT=http://127.0.0.1:1234/v1/models
LLM_API_KEY=dummy_key

# Optional: Database Configuration
DATABASE_URL=sqlite:///tasks.db

# Optional: Redis Configuration (for Celery queue)
REDIS_URL=redis://localhost:6379/0
