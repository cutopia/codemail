# Email Configuration
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your email credentials (use app password for Gmail)
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_app_password

# LLM Configuration (LM Studio local endpoint)
LLM_ENDPOINT=http://127.0.0.1:1234/v1/models
LLM_API_KEY=dummy_key  # LM Studio doesn't require real API key locally

# Task Database
DATABASE_URL=sqlite:///tasks.db

# Redis Configuration (for Celery queue - optional for Phase 1)
REDIS_URL=redis://localhost:6379/0

# Codemail Subject Prefix (default: "codemail:")
CODEMAIL_PREFIX=codemail:
